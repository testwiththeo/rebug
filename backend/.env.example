APP_NAME=Rebug API
ENVIRONMENT=production
PORT=8000
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/rebug
VIEWER_BASE_URL=https://viewer.example.com
BACKEND_PUBLIC_BASE_URL=https://api.example.com
CORS_ORIGINS=["https://viewer.example.com"]

REDIS_URL=redis://default:PASSWORD@HOST:6379/0
CELERY_BROKER_URL=redis://default:PASSWORD@HOST:6379/0
CELERY_RESULT_BACKEND=redis://default:PASSWORD@HOST:6379/1

TOKEN_ENCRYPTION_SECRET=replace-with-32-byte-random-secret
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

S3_ENDPOINT_URL=https://s3.example.com
S3_REGION_NAME=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=rebug-sessions

JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=https://api.example.com/api/v1/integrations/jira/callback
JIRA_SCOPES=read:jira-work write:jira-work offline_access
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Bug
JIRA_REPLAY_CUSTOM_FIELD=
JIRA_CLOUD_ID=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://api.example.com/api/v1/integrations/slack/callback
SLACK_SCOPES=incoming-webhook,chat:write
SLACK_DEFAULT_CHANNEL=
SLACK_INCOMING_WEBHOOK_URL=
